const HORARIO_FUNCIONAMENTO = `🗓 *HORÁRIO DE ATENDIMENTO*

━━━━━━━━━━━━━━━━━━
Segunda a Sexta: 08:00 às 18:00
Sábado: 08:00 às 16:00
